# syntax=docker/dockerfile:1.6

# ═══════════════════════════════════════════════════════════════
# Stage 1: Base con dependencias del SISTEMA
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache \
    # Canvas / pdfkit deps (existentes)
    cairo-dev \
    pango-dev \
    jpeg-dev \
    giflib-dev \
    librsvg-dev \
    pixman-dev \
    pkgconfig \
    build-base \
    g++ \
    python3 \
    fontconfig \
    ttf-dejavu \
    # 👇 NUEVO: Chromium + deps para Puppeteer
    chromium \
    nss \
    freetype \
    freetype-dev \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    && fc-cache -f

# 👇 NUEVO: indicarle a puppeteer que NO baje su propio Chromium
# (usamos el del sistema, instalado vía apk)
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ═══════════════════════════════════════════════════════════════
# Stage 2: Development
# ═══════════════════════════════════════════════════════════════
FROM base AS development
COPY package.json ./package.json
COPY package-lock.json ./package-lock.json
RUN npm install
COPY . .
EXPOSE 3000
CMD ["npx", "ts-node", "-r", "tsconfig-paths/register", "src/main.ts"]

# ═══════════════════════════════════════════════════════════════
# Stage 3: Builder (compila TypeScript a JavaScript)
# ═══════════════════════════════════════════════════════════════
FROM base AS builder

COPY package.json package-lock.json ./

RUN npm ci

COPY . .

RUN npm run build

RUN npm prune --production

# ═══════════════════════════════════════════════════════════════
# Stage 4: Production (imagen final mínima)
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS production
WORKDIR /app

# 👇 Librerías RUNTIME (sin -dev, más livianas)
RUN apk add --no-cache \
    # Canvas / pdfkit runtime (existentes)
    cairo \
    pango \
    jpeg \
    giflib \
    librsvg \
    pixman \
    fontconfig \
    ttf-dejavu \
    curl \
    tzdata \
    # 👇 NUEVO: Chromium + deps para Puppeteer en runtime
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    && fc-cache -f

# 👇 NUEVO: env vars para Puppeteer
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

ENV TZ=America/Mexico_City

# Usuario no-root por seguridad
RUN addgroup -S nodejs && adduser -S vortiz -G nodejs

# Copiar SOLO lo necesario del builder
COPY --from=builder --chown=vortiz:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=vortiz:nodejs /app/dist ./dist
COPY --from=builder --chown=vortiz:nodejs /app/package*.json ./

# Directorio uploads con permisos
RUN mkdir -p uploads && chown vortiz:nodejs uploads

USER vortiz

# Healthcheck a nivel Docker
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1

EXPOSE 3000

CMD ["node", "dist/main.js"]