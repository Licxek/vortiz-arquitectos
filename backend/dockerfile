# syntax=docker/dockerfile:1.6

# ═══════════════════════════════════════════════════════════════
# Stage 1: Base con dependencias compartidas
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache curl
COPY package*.json ./

# ═══════════════════════════════════════════════════════════════
# Stage 2: Development (lo que ya usas hoy)
# ═══════════════════════════════════════════════════════════════
FROM base AS development
RUN npm install
COPY . .
EXPOSE 3000
CMD ["npx", "ts-node", "-r", "tsconfig-paths/register", "src/main.ts"]

# ═══════════════════════════════════════════════════════════════
# Stage 3: Build (compila TypeScript a JavaScript)
# ═══════════════════════════════════════════════════════════════
FROM base AS builder
RUN npm ci
COPY . .
RUN npm run build
RUN npm prune --production

# ═══════════════════════════════════════════════════════════════
# Stage 4: Production (imagen final mínima)
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS production
WORKDIR /app

# curl para healthchecks
RUN apk add --no-cache curl

# Usuario no-root por seguridad
RUN addgroup -S nodejs && adduser -S vortiz -G nodejs

# Solo lo necesario desde el builder
COPY --from=builder --chown=vortiz:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=vortiz:nodejs /app/dist ./dist
COPY --from=builder --chown=vortiz:nodejs /app/package*.json ./

# Directorio uploads con permisos
RUN mkdir -p uploads && chown vortiz:nodejs uploads

USER vortiz

# Healthcheck a nivel Docker
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1

EXPOSE 3000

CMD ["node", "dist/main.js"]