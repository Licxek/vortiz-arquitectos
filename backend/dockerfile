# syntax=docker/dockerfile:1.6

# ═══════════════════════════════════════════════════════════════
# Stage 1: Base con dependencias del SISTEMA para compilar canvas
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS base
WORKDIR /app
RUN apk add --no-cache \
    cairo-dev \
    pango-dev \
    jpeg-dev \
    giflib-dev \
    librsvg-dev \
    pixman-dev \
    pkgconfig \
    build-base \
    g++ \
    python3 \
    fontconfig \
    ttf-dejavu \
    && fc-cache -f

# ═══════════════════════════════════════════════════════════════
# Stage 2: Development (mismo que tienes)
# ═══════════════════════════════════════════════════════════════
FROM base AS development
COPY package.json ./package.json
COPY package-lock.json ./package-lock.json
RUN npm install
COPY . .
EXPOSE 3000
CMD ["npx", "ts-node", "-r", "tsconfig-paths/register", "src/main.ts"]

# ═══════════════════════════════════════════════════════════════
# Stage 3: Builder (compila TypeScript a JavaScript)
# ═══════════════════════════════════════════════════════════════
FROM base AS builder

# 👇 FIX 1: copiar package.json ANTES de npm ci
COPY package.json package-lock.json ./

# npm ci es más rápido y reproducible que npm install (usa solo el lockfile)
RUN npm ci

# Ahora sí, copiar el resto del código
COPY . .

# Compilar TypeScript → JavaScript en /app/dist
RUN npm run build

# Quitar devDependencies para que la imagen final sea más pequeña
RUN npm prune --production

# ═══════════════════════════════════════════════════════════════
# Stage 4: Production (imagen final mínima)
# ═══════════════════════════════════════════════════════════════
FROM node:20-alpine AS production
WORKDIR /app

# 👇 FIX 2: librerías RUNTIME para canvas (sin -dev, más livianas)
# Sin esto, canvas falla con "Error loading shared library"
RUN apk add --no-cache \
    cairo \
    pango \
    jpeg \
    giflib \
    librsvg \
    pixman \
    fontconfig \
    ttf-dejavu \
    curl \
    tzdata \
    && fc-cache -f

# 👇 Zona horaria por defecto (puede ser override por docker-compose)
ENV TZ=America/Mexico_City

# Usuario no-root por seguridad
RUN addgroup -S nodejs && adduser -S vortiz -G nodejs

# Copiar SOLO lo necesario del builder
COPY --from=builder --chown=vortiz:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=vortiz:nodejs /app/dist ./dist
COPY --from=builder --chown=vortiz:nodejs /app/package*.json ./

# Directorio uploads con permisos
RUN mkdir -p uploads && chown vortiz:nodejs uploads

USER vortiz

# Healthcheck a nivel Docker
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/api/health || exit 1

EXPOSE 3000

CMD ["node", "dist/main.js"]